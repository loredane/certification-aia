# =============================================================================
# Stripe Data Architecture — Environment Variables
# Copy this file to .env and fill with your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (OLTP)
# -----------------------------------------------------------------------------
POSTGRES_DB=stripe_oltp
POSTGRES_USER=stripe_app
POSTGRES_PASSWORD=change_me_postgres_2026

# -----------------------------------------------------------------------------
# MinIO (S3-compatible Data Lake)
# -----------------------------------------------------------------------------
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_minio_2026
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_RAW=stripe-raw
MINIO_BUCKET_STAGING=stripe-staging
MINIO_BUCKET_ARCHIVE=stripe-archive

# FIX v3-mediums #11 : service account MinIO dedie pour Airbyte
# (policy scoped sur stripe-raw/* + stripe-staging/*), provisionne
# par le service minio-init au premier lancement.
AIRBYTE_S3_ACCESS_KEY=airbyte_svc
AIRBYTE_S3_SECRET=change_me_airbyte_s3_2026

# -----------------------------------------------------------------------------
# Snowflake (Cloud DWH)
# -----------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=xxxxxxx-xxxxxxx   # e.g. abc12345.eu-west-1
SNOWFLAKE_USER=DBT_USER
SNOWFLAKE_PASSWORD=change_me_snowflake_2026
SNOWFLAKE_ROLE=TRANSFORM_ROLE
SNOWFLAKE_DATABASE=STRIPE_ANALYTICS
SNOWFLAKE_WAREHOUSE=TRANSFORMING
SNOWFLAKE_SCHEMA=MARTS

# FIX v3-hauts: variable dédiée au user technique Airbyte (différente de DBT_USER).
# Référencée par airbyte/configs/snowflake_destination.yaml.
# Doit correspondre au password défini dans snowflake/init/01_setup_snowflake.sql
# pour AIRBYTE_USER (par défaut : Change_Me_Airbyte_2026!).
SNOWFLAKE_AIRBYTE_PASSWORD=change_me_airbyte_snowflake_2026

# -----------------------------------------------------------------------------
# MongoDB (NoSQL)
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo_2026
MONGO_DB=stripe_nosql
# FIX v3-mediums #5 : user applicatif Mongo (non-root) cree par init-mongo.sh.
# Password injecte via env, plus de hardcode dans un .js committe.
MONGO_APP_USER=stripe_app
MONGO_APP_PASSWORD=change_me_mongo_app_2026
# FIX v3-hauts: credentials pour la UI mongo-express (bindée sur 127.0.0.1)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=change_me_mongoexpress_2026

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BROKER=kafka:29092
KAFKA_EXTERNAL_BROKER=localhost:9092

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=change_me_fernet_key_base64_32b
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_webserver_secret

# -----------------------------------------------------------------------------
# ML Service (FastAPI)
# -----------------------------------------------------------------------------
ML_MODEL_PATH=/app/models/fraud_model.pkl
ML_API_PORT=8000
# FIX v3-hauts: liste CSV de clés API autorisées pour /score.
# Générer via : python -c "import secrets; print(','.join(secrets.token_urlsafe(32) for _ in range(2)))"
ML_API_KEYS=
# Mettre à 1 en DEV uniquement : autorise /score SANS clé si ML_API_KEYS vide.
# En prod : laisser à 0 et renseigner ML_API_KEYS.
ML_DEV_ALLOW_NO_AUTH=1
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_2026
