{
  "uid": "stripe-infra",
  "title": "Stripe — Infrastructure Health",
  "tags": ["stripe", "infra"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "datasource": "Prometheus", "expr": "count(up == 1)" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Services down",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] } } },
      "targets": [
        { "datasource": "Prometheus", "expr": "count(up == 0)" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Scrape duration per job",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "datasource": "Prometheus", "expr": "scrape_duration_seconds", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Up status timeline",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "datasource": "Prometheus", "expr": "up", "legendFormat": "{{job}} / {{instance}}" }
      ]
    }
  ]
}
