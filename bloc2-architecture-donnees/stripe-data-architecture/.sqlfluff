# =============================================================================
# FIX v3-mediums #16 : config sqlfluff pour les modeles dbt + snowflake.
# Usage :
#   pip install sqlfluff sqlfluff-templater-dbt
#   sqlfluff lint dbt/stripe_analytics/models
#   sqlfluff fix  dbt/stripe_analytics/models
# =============================================================================

[sqlfluff]
templater = dbt
dialect = snowflake
exclude_rules = L003, L009, L011, L027, L031, L034
max_line_length = 120
sql_file_exts = .sql

[sqlfluff:templater:dbt]
project_dir = ./dbt/stripe_analytics
profiles_dir = ./dbt
profile = stripe_analytics
target = dev

[sqlfluff:indentation]
indented_joins = false
indented_using_on = true
template_blocks_indent = false

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = upper
